/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-process module configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    withName: 'BAKTA' {
        label = 'process_medium'
        ext.args = {
            def args = []

            // Annotation
            args << "--min-contig-length ${params.bakta_min_contig_length}"
            args << "--translation-table ${params.bakta_translation_table}"
            if (params.bakta_prodigal_tf)          args << "--prodigal-tf ${params.bakta_prodigal_tf}"
            args << "--locus-tag-increment ${params.bakta_locus_tag_increment}"
            if (params.bakta_keep_contig_headers)  args << '--keep-contig-headers'
            if (params.bakta_compliant)            args << '--compliant'
            if (params.bakta_replicons)            args << "--replicons ${params.bakta_replicons}"
            if (params.bakta_hmms)                 args << "--hmms ${params.bakta_hmms}"
            if (params.bakta_meta)                 args << '--meta'

            // Skip flags
            if (params.bakta_skip_trna)            args << '--skip-trna'
            if (params.bakta_skip_tmrna)           args << '--skip-tmrna'
            if (params.bakta_skip_rrna)            args << '--skip-rrna'
            if (params.bakta_skip_ncrna)           args << '--skip-ncrna'
            if (params.bakta_skip_ncrna_region)    args << '--skip-ncrna-region'
            if (params.bakta_skip_crispr)          args << '--skip-crispr'
            if (params.bakta_skip_cds)             args << '--skip-cds'
            if (params.bakta_skip_pseudo)          args << '--skip-pseudo'
            if (params.bakta_skip_sorf)            args << '--skip-sorf'
            if (params.bakta_skip_gap)             args << '--skip-gap'
            if (params.bakta_skip_ori)             args << '--skip-ori'
            if (params.bakta_skip_filter)          args << '--skip-filter'
            if (params.bakta_skip_plot)            args << '--skip-plot'

            if (params.bakta_extra_args)           args << params.bakta_extra_args
            return args.join(' ')
        }
        publishDir = [
            path: { "${params.outdir}/bakta/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{gff3,gbff,fna,ffn,faa,tsv,json,txt,png,svg}'
        ]
    }

    withName: 'BAKTA_DOWNLOAD_DB' {
        label = 'process_single'
    }

    withName: 'EGGNOG_DOWNLOAD_DB' {
        label = 'process_single'
    }

    withName: 'EGGNOG_MAPPER' {
        label = 'process_medium'
        ext.args = {
            def args = []

            // Search
            args << "-m ${params.eggnog_search_mode}"
            args << "--itype ${params.eggnog_itype}"
            if (params.eggnog_pident != null)              args << "--pident ${params.eggnog_pident}"
            if (params.eggnog_query_cover != null)         args << "--query_cover ${params.eggnog_query_cover}"
            if (params.eggnog_subject_cover != null)       args << "--subject_cover ${params.eggnog_subject_cover}"
            args << "--evalue ${params.eggnog_evalue}"
            if (params.eggnog_score != null)               args << "--score ${params.eggnog_score}"

            // Diamond-specific options (only applied when search mode is diamond)
            if (params.eggnog_search_mode == 'diamond') {
                args << "--sensmode ${params.eggnog_sensmode}"
                args << "--dmnd_iterate ${params.eggnog_dmnd_iterate}"
                args << "--dmnd_algo ${params.eggnog_dmnd_algo}"
                if (params.eggnog_matrix)                  args << "--matrix ${params.eggnog_matrix}"
                if (params.eggnog_dmnd_frameshift != null) args << "--dmnd_frameshift ${params.eggnog_dmnd_frameshift}"
                if (params.eggnog_gapopen != null)         args << "--gapopen ${params.eggnog_gapopen}"
                if (params.eggnog_gapextend != null)       args << "--gapextend ${params.eggnog_gapextend}"
                if (params.eggnog_block_size != null)      args << "--block_size ${params.eggnog_block_size}"
                if (params.eggnog_index_chunks != null)    args << "--index_chunks ${params.eggnog_index_chunks}"
                if (params.eggnog_outfmt_short)            args << '--outfmt_short'
                if (params.eggnog_dmnd_ignore_warnings)    args << '--dmnd_ignore_warnings'
            }

            // Annotation
            args << "--seed_ortholog_evalue ${params.eggnog_seed_ortholog_evalue}"
            if (params.eggnog_seed_ortholog_score != null) args << "--seed_ortholog_score ${params.eggnog_seed_ortholog_score}"
            args << "--tax_scope ${params.eggnog_tax_scope}"
            args << "--tax_scope_mode ${params.eggnog_tax_scope_mode}"
            args << "--target_orthologs ${params.eggnog_target_orthologs}"
            if (params.eggnog_target_taxa)                 args << "--target_taxa ${params.eggnog_target_taxa}"
            if (params.eggnog_excluded_taxa)               args << "--excluded_taxa ${params.eggnog_excluded_taxa}"
            args << "--go_evidence ${params.eggnog_go_evidence}"
            args << "--pfam_realign ${params.eggnog_pfam_realign}"
            if (params.eggnog_no_annot)                    args << '--no_annot'
            if (params.eggnog_dbmem)                       args << '--dbmem'
            if (params.eggnog_report_orthologs)            args << '--report_orthologs'
            if (params.eggnog_report_no_hits)              args << '--report_no_hits'
            if (params.eggnog_md5)                         args << '--md5'
            if (params.eggnog_excel)                       args << '--excel'
            if (params.eggnog_no_file_comments)            args << '--no_file_comments'

            if (params.eggnog_extra_args)                  args << params.eggnog_extra_args
            return args.join(' ')
        }
        publishDir = [
            path: { "${params.outdir}/eggnog/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.emapper.*'
        ]
    }
}
