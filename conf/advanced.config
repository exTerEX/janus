/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Advanced / internal parameter defaults
    These are intentionally hidden from the --help output. Override via CLI or a
    custom params file if needed (e.g. -params-file my_params.json).
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {

    // ── Bakta – annotation ────────────────────────────────────────────────────
    bakta_min_contig_length      = 1           // --min-contig-length
    bakta_translation_table      = 11          // --translation-table: 11 (bacteria), 4 (Mycoplasma), 25 (SR1)
    bakta_prodigal_tf            = null        // --prodigal-tf
    bakta_locus_tag_increment    = 1           // --locus-tag-increment: 1, 5, or 10
    bakta_keep_contig_headers    = false       // --keep-contig-headers
    bakta_compliant              = false       // --compliant (Genbank/ENA/DDJB compliance)
    bakta_replicons              = null        // --replicons (tsv/csv replicon table)
    bakta_hmms                   = null        // --hmms (custom HMM file)
    bakta_meta                   = false       // --meta (metagenome mode)
    bakta_extra_args             = ''          // additional CLI args passed verbatim to bakta

    // ── Bakta – skip flags ────────────────────────────────────────────────────
    bakta_skip_trna              = true        // --skip-trna
    bakta_skip_tmrna             = true        // --skip-tmrna
    bakta_skip_rrna              = true        // --skip-rrna
    bakta_skip_ncrna             = true        // --skip-ncrna
    bakta_skip_ncrna_region      = true        // --skip-ncrna-region
    bakta_skip_crispr            = true        // --skip-crispr
    bakta_skip_cds               = true        // --skip-cds
    bakta_skip_pseudo            = true        // --skip-pseudo
    bakta_skip_sorf              = true        // --skip-sorf
    bakta_skip_gap               = true        // --skip-gap
    bakta_skip_ori               = true        // --skip-ori
    bakta_skip_filter            = false       // --skip-filter
    bakta_skip_plot              = false       // --skip-plot

    // ── eggNOG-mapper – search ────────────────────────────────────────────────
    eggnog_search_mode           = 'diamond'   // -m: diamond | mmseqs | hmmer | no_search | cache | novel_fams
    eggnog_itype                 = 'proteins'  // --itype: CDS | proteins | genome | metagenome
    eggnog_pident                = null        // --pident (min % identity, 0-100)
    eggnog_query_cover           = null        // --query_cover (min % query coverage, 0-100)
    eggnog_subject_cover         = null        // --subject_cover (min % subject coverage, 0-100)
    eggnog_evalue                = 0.001       // --evalue
    eggnog_score                 = null        // --score (min bit score)

    // Diamond search options (used when eggnog_search_mode = 'diamond')
    eggnog_sensmode              = 'sensitive' // --sensmode: default | fast | mid-sensitive | sensitive | more-sensitive | very-sensitive | ultra-sensitive
    eggnog_dmnd_iterate          = 'yes'       // --dmnd_iterate: yes | no
    eggnog_dmnd_algo             = 'auto'      // --dmnd_algo: auto | 0 | 1 | ctg
    eggnog_matrix                = null        // --matrix: BLOSUM62 | BLOSUM90 | BLOSUM80 | BLOSUM50 | BLOSUM45 | PAM250 | PAM70 | PAM30
    eggnog_dmnd_frameshift       = null        // --dmnd_frameshift (recommended: 15 for translated searches)
    eggnog_gapopen               = null        // --gapopen
    eggnog_gapextend             = null        // --gapextend
    eggnog_block_size            = null        // --block_size (diamond -b)
    eggnog_index_chunks          = null        // --index_chunks (diamond -c)
    eggnog_outfmt_short          = false       // --outfmt_short
    eggnog_dmnd_ignore_warnings  = false       // --dmnd_ignore_warnings

    // ── eggNOG-mapper – annotation ────────────────────────────────────────────
    eggnog_seed_ortholog_evalue  = 0.001       // --seed_ortholog_evalue
    eggnog_seed_ortholog_score   = null        // --seed_ortholog_score
    eggnog_tax_scope             = 'auto'      // --tax_scope: auto | bacteria | eukaryota | archaea | prokaryota_broad | ... | none
    eggnog_tax_scope_mode        = 'inner_narrowest' // --tax_scope_mode: broadest | inner_broadest | inner_narrowest | narrowest
    eggnog_target_orthologs      = 'all'       // --target_orthologs: one2one | many2one | one2many | many2many | all
    eggnog_target_taxa           = null        // --target_taxa (comma-separated tax IDs)
    eggnog_excluded_taxa         = null        // --excluded_taxa (comma-separated tax IDs)
    eggnog_go_evidence           = 'non-electronic' // --go_evidence: experimental | non-electronic | all
    eggnog_pfam_realign          = 'none'      // --pfam_realign: none | realign | denovo
    eggnog_no_annot              = false       // --no_annot (skip functional annotation)
    eggnog_dbmem                 = false       // --dbmem (load eggnog.db into memory)
    eggnog_report_orthologs      = true        // --report_orthologs
    eggnog_report_no_hits        = true        // --report_no_hits
    eggnog_md5                   = true        // --md5
    eggnog_excel                 = true        // --excel
    eggnog_no_file_comments      = true        // --no_file_comments
    eggnog_extra_args            = ''          // additional CLI args passed verbatim to emapper.py
}
